# IBM deployment + PMOMax runtime environment
# Copy of root .env with IBM-specific additions (placeholders only).

GOOGLE_API_KEY=""
PROJECT_ID=""
REGION="us-east1"
REGION_PRIMARY="us-east1"
IMAGE_NAME="pmomax"
IMAGE_TAG="latest"
SERVICE_NAME="pmomax"
SECRET_NAME=""
SECRET_REFERENCE=""
ENVIRONMENT="Production"

MEMORY=512Mi
CPU=1
TIMEOUT=300
MAX_INSTANCES=10
MIN_INSTANCES=0
CONCURRENCY=80

ENABLE_MONITORING=true
ALERT_EMAIL=
ERROR_THRESHOLD_PERCENT=5

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=30

DEBUG=false
LOG_LEVEL=info

APP_LABEL=pmomax
ENV_LABEL=production
OWNER_LABEL=platform-team

ENABLE_VULN_SCAN=false
FAIL_ON_HIGH_VULNS=true

# IBM LLM provider (optional)
LLM_PROVIDER=google
IBM_WX_APIKEY=""
IBM_WX_PROJECT_ID=""
IBM_WX_REGION="us-south"
IBM_WX_MODEL_ID=""

# IBM Cloud deployment settings
IBM_CLOUD_REGION="us-south"
IBM_RESOURCE_GROUP="default"
IBM_CLOUD_API_KEY=""
ICR_NAMESPACE=""
IKS_CLUSTER_NAME=""
ROKS_CLUSTER_NAME=""
