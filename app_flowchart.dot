digraph PMOMaxAppFlow {
    rankdir=LR;
    node [shape=box, style=filled, fontsize=14, fontname="Arial"];
    CustomerTenant [label="Customer Tenant:\nUser", fillcolor="#E3F2FD"];
    Frontend [label="Frontend:\nReact SPA", fillcolor="#F5F5F5"];
    PartnerTenant [label="Partner Tenant:\nBackend API (Express)", fillcolor="#FFF9C4"];
    AIParsing [label="AI/Parsing Logic\n(Gemini, Local)", fillcolor="#F3E5F5"];
    GCP [label="Google Cloud Platform:\nCloud Run / GKE", fillcolor="#E8F5E9"];

    CustomerTenant -> Frontend [label="Uploads Text/Document"];
    Frontend -> PartnerTenant [label="Sends Data"];
    PartnerTenant -> AIParsing [label="Parse/AI/Export"];
    AIParsing -> PartnerTenant [label="Returns PID/Reply"];
    PartnerTenant -> Frontend [label="Returns Data"];
    Frontend -> CustomerTenant [label="Shows PID/Assistant"];
    Frontend -> PartnerTenant [label="Export Request"];
    PartnerTenant -> Frontend [label="Export File"];
    PartnerTenant -> GCP [label="Compliance/Health"];
    GCP -> Frontend [label="Hosts"];
    GCP -> PartnerTenant [label="Hosts"];
}
