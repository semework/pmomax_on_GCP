# Marketplace values interpolation for deployer runtime
APP_INSTANCE_NAME="${APP_INSTANCE_NAME:-pmo-architect}"
NAMESPACE="${NAMESPACE:-pmomax}"
SERVICE_ACCOUNT="${deployerServiceAccount:-deployer-sa}"
DOMAIN="${DOMAIN:-pmomax.example.com}"
REPORTING_SECRET="${reportingSecret:-reporting-secret}"
GCP_PROJECT_ID="${GCP_PROJECT_ID:-katalyststreet-public}"
NODE_ENV=production

DEPLOYER_IMAGE="${deployerImageRepo:-us-docker.pkg.dev/katalyststreet-public/pmomax/deployer}:${deployerImageTag:-1.0.0}"
PMOMAX_APP_IMAGE="${pmomaxAppRepo:-us-docker.pkg.dev/katalyststreet-public/pmomax/pmomax}:${pmomaxAppTag:-1.0.0}"
PMOMAX_APP_PORT="${PMOMAX_APP_PORT:-8080}"
PARTNER_ID="${PARTNER_ID:-katalyststreet}"
PRODUCT_ID="${PRODUCT_ID:-pmo-max}"
TESTER_IMAGE="${TESTER_IMAGE:-us-docker.pkg.dev/katalyststreet-public/pmomax/deployer:1.0.0}"
AGENT_ENCODED_KEY="${AGENT_ENCODED_KEY:-}"
AGENT_REPORT_DIR="${AGENT_REPORT_DIR:-/var/lib/ubbagent/reports}"
AGENT_CONSUMER_ID="${AGENT_CONSUMER_ID:-project:${GCP_PROJECT_ID}}"
LISTING_ID="${LISTING_ID:-pmo-max.endpoints.katalyststreet-public.cloud.goog}"
