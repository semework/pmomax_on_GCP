digraph PMOMaxAppFlow {
    rankdir=TB;
    size="8,12";
    node [shape=box, style=filled, fontsize=16, fontname="Arial", width=2, height=1.2];
    CustomerTenant [label="Customer Tenant\n(User)", fillcolor="#E3F2FD"];
    Frontend [label="Frontend\n(React SPA)", fillcolor="#F5F5F5"];
    PartnerTenant [label="Partner Tenant\n(Backend API)", fillcolor="#FFF9C4"];
    AIParsing [label="AI/Parsing Logic\n(Gemini, Local)", fillcolor="#F3E5F5"];
    GCP [label="Google Cloud Platform\n(Cloud Run / GKE)", fillcolor="#E8F5E9"];

    CustomerTenant -> Frontend [label="Uploads Text/Document", fontname="Arial", fontsize=12];
    Frontend -> PartnerTenant [label="Sends Data", fontname="Arial", fontsize=12];
    PartnerTenant -> AIParsing [label="Parse/AI/Export", fontname="Arial", fontsize=12];
    AIParsing -> PartnerTenant [label="Returns PID/Reply", fontname="Arial", fontsize=12];
    PartnerTenant -> Frontend [label="Returns Data", fontname="Arial", fontsize=12];
    Frontend -> CustomerTenant [label="Shows PID/Assistant", fontname="Arial", fontsize=12];
    Frontend -> PartnerTenant [label="Export Request", fontname="Arial", fontsize=12];
    PartnerTenant -> Frontend [label="Export File", fontname="Arial", fontsize=12];
    PartnerTenant -> GCP [label="Compliance/Health", fontname="Arial", fontsize=12];
    GCP -> Frontend [label="Hosts", fontname="Arial", fontsize=12];
    GCP -> PartnerTenant [label="Hosts", fontname="Arial", fontsize=12];
}
