# ==============================
# Node / build outputs (NEVER ship)
# ==============================
node_modules
dist
build
coverage
.vite
.cache
.npm
.pnpm-store
dist 2

# ==============================
# Logs
# ==============================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs

# ==============================
# OS / Editor
# ==============================
.DS_Store
Thumbs.db
.vscode
.idea

# ==============================
# Git / archives (CRITICAL - excludes SDK tarballs)
# ==============================
.git
.gitignore
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
google-cloud-sdk*
pmomax-video-assets*

# ==============================
# Python / local envs
# ==============================
venv
.venv
__pycache__

# ==============================
# Test / automation artifacts
# ==============================
playwright-report
test-results
test-fixtures
screenshots
videos
traces

# ==============================
# Marketing / docs / media (CRITICAL)
# ==============================
pmomax-video-assets
promo
docs
documentation
presentations
*.pptx
*.pdf
*.docx
*.md
*.png
*.svg
*.drawio.xml

# ==============================
# Allow app logos in public
# ==============================
!public/logos/
!public/logos/**

# ==============================
# Data / exports / local demo artifacts
# ==============================
exports
output
out
tmp
temp
*.csv
*.xlsx
*.jsonl

# ==============================
# Quarantine / duplicates (DO NOT BUILD)
# ==============================
__quarantine_duplicates__
duplicates_review_*
_patch_steps
archived_js_duplicates

# ==============================
# Backup copies
# ==============================
PMOMAXX_COPY
PMOMAXX2
PMOMax_corrected

# ==============================
# Enforce: no accidental src folder
# ==============================
src
src/**

# Allow build shims used by Vite
!src/shims/
!src/shims/**

# ==============================
# Env files (do not ship secrets)
# ==============================

# Env files (do not ship secrets)
.env
.env.local
.env.*.local

# Allow server to load .env when explicitly provided
!.env

# Keep production env if you explicitly need it
!.env.production


