apiVersion: v1
kind: Pod
metadata:
  name: ${APP_INSTANCE_NAME}-tester
  namespace: ${NAMESPACE}
  labels:
    app: ${APP_INSTANCE_NAME}-tester
spec:
  restartPolicy: Never
  containers:
    - name: tester
      image: curlimages/curl:8.12.1
      command:
        - /bin/sh
        - -c
        - |
          set -eu
          BASE_URL="http://${APP_INSTANCE_NAME}.${NAMESPACE}.svc.cluster.local"
          echo "Checking ${BASE_URL}/health"
          code="$(curl -sS -o /tmp/health.out -w '%{http_code}' "${BASE_URL}/health" || true)"
          echo "HTTP ${code}"
          if [ "${code}" != "200" ]; then
            echo "Health check failed"
            cat /tmp/health.out || true
            exit 1
          fi
          echo "Health check passed"
