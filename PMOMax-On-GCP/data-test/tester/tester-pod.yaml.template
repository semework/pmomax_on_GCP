apiVersion: v1
kind: Pod
metadata:
  name: "$name-tester"
  namespace: "$namespace"
  labels:
    app: "$name"
  annotations:
    marketplace.cloud.google.com/verification: test
spec:
  containers:
  - name: tester
    image: us-docker.pkg.dev/katalyststreet-public/pmomax/pmo-architect:20260303-233534
    command: ["/bin/sh", "-c"]
    args:
    - |
      echo "Starting PMOMax Health Check..."
      until curl -fsS "http://$name/health"; do
        echo "Waiting for service..."
        sleep 5
      done
      echo "Health Check Passed!"
      exit 0
  restartPolicy: Never
