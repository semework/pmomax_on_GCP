apiVersion: v1
kind: Pod
metadata:
  name: "$name-tester"
  labels:
    app: "$name"
  annotations:
    marketplace.cloud.google.com/verification: test
spec:
  containers:
  - name: tester
    image: "$TESTER_IMAGE"
    command: ["/bin/sh", "-c"]
    args:
    - |
      set -e
      echo "Starting PMOMax Health Check..."
      # Wait for the service to be reachable via K8s DNS
      ATTEMPTS=0
      until curl -fsS "http://$name/health" || [ $ATTEMPTS -eq 12 ]; do
        echo "Waiting for PMOMax service at http://$name/health..."
        ATTEMPTS=$((ATTEMPTS+1))
        sleep 10
      done
      echo "PMOMax is Healthy!"
  restartPolicy: Never
