apiVersion: v1
kind: Pod
metadata:
  name: ${APP_INSTANCE_NAME}-tester
  namespace: ${NAMESPACE}
  labels:
    app: ${APP_INSTANCE_NAME}
  annotations:
    marketplace.cloud.google.com/verification: test
spec:
  restartPolicy: Never
  containers:
  - name: tester
    image: ${TESTER_IMAGE}
    command:
    - /bin/sh
    - -c
    - |
      set -e
      echo "Fallback tester pod running"
      echo "namespace=${NAMESPACE} app=${APP_INSTANCE_NAME}"
      exit 0
