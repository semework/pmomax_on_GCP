# Marketplace values interpolation for deployer runtime
APP_INSTANCE_NAME="${APP_INSTANCE_NAME:-pmo-architect}"
NAMESPACE="${NAMESPACE:-pmomax}"
SERVICE_ACCOUNT="${deployerServiceAccount:-deployer-sa}"
DOMAIN="${DOMAIN:-pmomax.example.com}"
REPORTING_SECRET="${reportingSecret:-reporting-secret}"
GCP_PROJECT_ID="${GCP_PROJECT_ID:-katalyststreet-public}"
NODE_ENV=production

DEPLOYER_IMAGE="${deployerImageRepo:-us-docker.pkg.dev/katalyststreet-public/pmomax/deployer}:${deployerImageTag:-20260303-220259}"
PMOMAX_APP_IMAGE="${pmomaxAppRepo:-us-docker.pkg.dev/katalyststreet-public/pmomax/pmo-architect}:${pmomaxAppTag:-20260303-233534}"
PMOMAX_APP_PORT="${PMOMAX_APP_PORT:-8080}"
