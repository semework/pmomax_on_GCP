# Marketplace values interpolation for deployer runtime
APP_INSTANCE_NAME="${APP_INSTANCE_NAME:-pmo-architect}"
NAMESPACE="${NAMESPACE:-}"
SERVICE_ACCOUNT="${deployerServiceAccount:-deployer-sa}"
DOMAIN="${DOMAIN:-pmomax.example.com}"
REPORTING_SECRET="${reportingSecret:-reporting-secret}"
GCP_PROJECT_ID="${GCP_PROJECT_ID:-katalyststreet-public}"
NODE_ENV=production

DEPLOYER_IMAGE="${DEPLOYER_IMAGE:-${deployerImageRegistry:-us-docker.pkg.dev}/${deployerImageRepo:-katalyststreet-public/pmomax/deployer}:${deployerImageTag:-1.3}}"
PMOMAX_APP_IMAGE="${PMOMAX_APP_IMAGE:-${pmomaxAppRegistry:-us-east1-docker.pkg.dev}/${pmomaxAppRepo:-katalyststreet-public/apps/pmo-architect}:${pmomaxAppTag:-1.0.1}}"
PMOMAX_APP_PORT="${PMOMAX_APP_PORT:-8080}"
ubbagentImageRegistry="${ubbagentImageRegistry:-us-docker.pkg.dev}"
ubbagentImageRepo="${ubbagentImageRepo:-katalyststreet-public/pmomax/ubbagent}"
ubbagentImageTag="${ubbagentImageTag:-1.3.8}"
PARTNER_ID="${PARTNER_ID:-katalyststreet}"
PRODUCT_ID="${PRODUCT_ID:-pmomax}"
TESTER_IMAGE="${TESTER_IMAGE:-${testerImageRegistry:-docker.io}/curlimages/curl:8.12.1}"
