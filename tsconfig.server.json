{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,

    "strict": false,
    "skipLibCheck": true,

    "types": ["node"],
    "lib": ["ES2022"],

    "resolveJsonModule": true
  },
  "include": [
    "server/**/*.ts",
    "server/**/*.mts",
    "server/**/*.cts"
  ],
  "exclude": [
    "**/*.test.*",
    "**/*.spec.*",

    "lib/**",
    "components/**",
    "hooks/**",
    "scripts/**",
    "workers/**",
    "public/**",
    "dist/**",
    "node_modules/**"
  ]
}
